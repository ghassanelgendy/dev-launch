{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AppConfig",
  "type": "object",
  "properties": {
    "app_name": { "type": "string" },
    "environment": { "type": "string", "enum": ["dev", "staging", "prod"] },
    "image": {
      "type": "object",
      "properties": {
        "repository": { "type": "string" },
        "tag": { "type": "string" }
      },
      "required": ["repository", "tag"]
    },
    "container": {
      "type": "object",
      "properties": {
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
      },
      "required": ["port"]
    },
    "replicas": { "type": "integer", "minimum": 1 },
    "domain": { "type": "string" },
    "resources": {
      "type": "object",
      "properties": {
        "requests": {
          "type": "object",
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" }
          }
        },
        "limits": {
          "type": "object",
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" }
          }
        }
      }
    },
    "health": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "path": { "type": "string" },
        "initial_delay_seconds": { "type": "integer" }
      }
    },
    "monitoring": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "metrics_path": { "type": "string" }
      }
    }
  },
  "required": ["app_name", "environment", "image", "container", "replicas", "domain"]
}
